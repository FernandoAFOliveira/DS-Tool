flowchart LR

Head["head"] --> N1["node: A"]
N1 --> N2["node: B"]
N2 --> N3["node: C"]
N3 --> Null["null"]

N1 -. stores .-> D1["data + next reference"]
Insert["insert/remove: change links"] -.-> N2
Search["access index 2: walk from head"] -.-> N3

class Head,Null note
class N1,N2,N3 data
class D1 action
class Insert,Search focus

classDef data fill:#1E293B,stroke:#38BDF8,stroke-width:2px,color:#E5E7EB;
classDef focus fill:#78350F,stroke:#F59E0B,stroke-width:3px,color:#FFF7ED;
classDef action fill:#064E3B,stroke:#34D399,stroke-width:2px,color:#ECFDF5;
classDef note fill:#4C1D95,stroke:#C084FC,stroke-width:2px,color:#F5F3FF;
classDef warning fill:#7F1D1D,stroke:#F87171,stroke-width:2px,color:#FEF2F2;
