flowchart LR
subgraph Canvas[" "]
    direction LR

    LeftOps["addFirst / pollFirst"] --> Front["front: A"]
    Front --> B["B"] --> C["C"] --> Rear["rear: D"]
    Rear --> RightOps["addLast / pollLast"]

    StackUse["Can act like a stack"] -.-> Rear
    QueueUse["Can act like a queue"] -.-> Front

end

class Front,Rear focus
class B,C data
class LeftOps,RightOps action
class StackUse,QueueUse note

style Canvas fill:#0F172A,stroke:#0F172A;

classDef data fill:#1E293B,stroke:#38BDF8,stroke-width:2px,color:#F8FAFC;
classDef focus fill:#78350F,stroke:#F59E0B,stroke-width:3px,color:#FFF7ED;
classDef action fill:#064E3B,stroke:#10B981,stroke-width:2px,color:#ECFDF5;
classDef note fill:#4C1D95,stroke:#A78BFA,stroke-width:2px,color:#F5F3FF;
classDef warning fill:#7F1D1D,stroke:#F87171,stroke-width:2px,color:#FEF2F2;
