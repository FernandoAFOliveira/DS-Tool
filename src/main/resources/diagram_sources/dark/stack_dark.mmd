flowchart TB

Push["push: add here"] --> Top["top: 30"]
Top --> Mid["20"]
Mid --> Bottom["10"]
Bottom --> Base["bottom"]
Top --> Pop["pop and peek happen here"]

Rule["LIFO: last in, first out"] -.-> Top

class Top focus
class Mid,Bottom data
class Push,Pop action
class Base,Rule note

