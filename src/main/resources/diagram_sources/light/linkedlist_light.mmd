flowchart LR

Head["head"] --> N1["node: A"]
N1 --> N2["node: B"]
N2 --> N3["node: C"]
N3 --> Null["null"]

N1 -. stores .-> D1["data + next reference"]
Insert["insert/remove: change links"] -.-> N2
Search["access index 2: walk from head"] -.-> N3

class Head,Null note
class N1,N2,N3 data
class D1 action
class Insert,Search focus

classDef data fill:#E3F2FD,stroke:#1565C0,stroke-width:2px,color:#0D1B2A;
classDef focus fill:#FFE0B2,stroke:#EF6C00,stroke-width:3px,color:#111827;
classDef action fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px,color:#111827;
classDef note fill:#F3E5F5,stroke:#8E24AA,stroke-width:2px,color:#111827;
classDef warning fill:#FFEBEE,stroke:#C62828,stroke-width:2px,color:#111827;
